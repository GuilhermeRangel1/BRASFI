MYSQL_IMAGE=mysql:8.0

DB_NAME=BRASFI
DB_USER=root
DB_PASSWORD=admin123
DB_LOCAL_PORT=3307

APP_PORT=8080
APP_CONTAINER_NAME=webapp
FRONTEND_PORT=3000
FRONTEND_CONTAINER_NAME=brasfi-frontend

APP_CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:8080
SEED_DEMO_DATA=true
ADMIN_EMAIL=admin@brasfi.com
ADMIN_PASSWORD=admin123
ADMIN_CPF=00000000000
ALLOW_PRIVILEGED_REGISTRATION=false

DDL_AUTO=update
SHOW_SQL=true
FORMAT_SQL=true
HIBERNATE_SQL_LOG_LEVEL=DEBUG
HIBERNATE_BINDER_LOG_LEVEL=TRACE
